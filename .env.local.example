# 项目设置
NEXT_PUBLIC_APP_NAME="AI Email Writer"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# AI 服务配置 - 支持所有兼容 OpenAI / Anthropic 协议的服务商
# AI_PROTOCOL: 协议类型，填写 'openai' 或 'anthropic'
AI_PROTOCOL="openai"

# 你的 API 密钥
AI_API_KEY="your-api-key-here"

# 服务端地址（OpenAI 兼容协议使用 /v1/chat/completions 结尾）
# OpenAI 官方:      https://api.openai.com/v1/chat/completions
# 阿里云百炼:       https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
# DeepSeek:         https://api.deepseek.com/v1/chat/completions
AI_API_URL="https://api.openai.com/v1/chat/completions"

# 模型名称
AI_MODEL="gpt-4o"

# 数据库配置 (PostgreSQL)
DATABASE_URL="postgresql://your_user:your_password@localhost:5432/emailwriter?schema=public"
DIRECT_URL="postgresql://your_user:your_password@localhost:5432/emailwriter?schema=public"

# NextAuth Secret (生成命令: openssl rand -base64 32)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-not-for-production-use"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub OAuth
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# 管理员邮箱 (逗号分隔)
ADMIN_EMAILS=""
